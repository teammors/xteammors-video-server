<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_PATH" value="./logs"/>
    
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <logger name="com.xteam.video" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="org.springframework.web" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="org.apache.ibatis" level="OFF" additivity="false"/>
    <logger name="org.apache.ibatis.session" level="OFF" additivity="false"/>
    <logger name="org.apache.ibatis.session.defaults" level="OFF" additivity="false"/>
    <logger name="org.apache.ibatis.executor" level="OFF" additivity="false"/>
    <logger name="org.mybatis.spring" level="OFF" additivity="false"/>
    <logger name="org.mybatis.spring.SqlSessionTemplate" level="OFF" additivity="false"/>
    <logger name="com.baomidou.mybatisplus" level="OFF" additivity="false"/>
    <logger name="com.zaxxer.hikari" level="OFF" additivity="false"/>
    <logger name="org.springframework.jdbc" level="OFF" additivity="false"/>
    <logger name="org.springframework.jdbc.datasource" level="OFF" additivity="false"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>